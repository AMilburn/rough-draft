{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "declaration": true,
        "declarationDir": "dist",
        "outDir": "dist",
        "module": "esnext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src/components/**/*"
    ],
    "exclude": [
        "node_modules",
        "src/app",
        "dist"
    ]
}